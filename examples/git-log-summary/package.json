{
  "name": "@ganderbite/example-git-log-summary",
  "version": "0.1.0",
  "description": "A two-step example flow that demonstrates step.script(): capture 20 recent git commits, then ask Claude to write a short changelog entry.",
  "private": true,
  "type": "module",
  "main": "./dist/flow.js",
  "exports": {
    ".": "./dist/flow.js"
  },
  "files": [
    "dist",
    "prompts",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "echo 'no unit tests — run relay test . with relay installed'"
  },
  "peerDependencies": {
    "@ganderbite/relay-core": "^1.0.0"
  },
  "devDependencies": {
    "@ganderbite/relay-core": "workspace:*",
    "typescript": "6.0.3"
  },
  "relay": {
    "flowName": "git-log-summary",
    "displayName": "Git Log Summary",
    "tags": [
      "script",
      "git",
      "example"
    ],
    "estimatedCostUsd": {
      "min": 0.0,
      "max": 0.01
    },
    "estimatedDurationMin": {
      "min": 1,
      "max": 3
    },
    "audience": [
      "dev"
    ]
  }
}
