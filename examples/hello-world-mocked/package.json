{
  "name": "hello-world-mocked",
  "version": "0.1.0",
  "description": "The mocked twin of hello-world — runs the same two-step flow against a MockProvider with no Claude binary, subscription, or API key.",
  "private": true,
  "type": "module",
  "main": "./dist/flow.js",
  "exports": {
    ".": "./dist/flow.js"
  },
  "files": [
    "dist",
    "prompts",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "relay test .",
    "run-mocked": "node dist/run-mocked.js"
  },
  "peerDependencies": {
    "@relay/core": "^1.0.0"
  },
  "devDependencies": {
    "@relay/core": "workspace:*",
    "@types/node": "25.6.0",
    "typescript": "6.0.3"
  },
  "relay": {
    "displayName": "Hello World (Mocked)",
    "tags": [
      "example",
      "tutorial",
      "testing"
    ],
    "estimatedCostUsd": {
      "min": 0.0,
      "max": 0.0
    },
    "estimatedDurationMin": {
      "min": 1,
      "max": 1
    },
    "audience": [
      "dev"
    ]
  }
}
