{
  "name": "relay",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.7.0",
  "engines": {
    "node": ">=25.8"
  },
  "scripts": {
    "build": "pnpm -r build",
    "typecheck": "pnpm -r --parallel typecheck",
