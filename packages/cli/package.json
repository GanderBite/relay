{
  "name": "@relay/cli",
  "version": "0.1.0",
  "description": "Run deterministic multi-step Claude Code workflows with checkpoint and resume.",
  "private": false,
  "type": "module",
  "main": "./dist/cli.js",
  "types": "./dist/cli.d.ts",
  "exports": {
    ".": {
      "types": "./dist/cli.d.ts",
      "import": "./dist/cli.js"
    }
  },
  "bin": {
    "relay": "./bin/relay.js"
  },
  "files": [
    "bin",
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:smoke": "vitest run --config vitest.smoke.config.ts",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@relay/core": "workspace:^",
    "@relay/generator": "workspace:^",
    "chalk": "^5.4.1",
    "chokidar": "^5.0.0",
    "commander": "13.1.0",
    "log-update": "^7.2.0",
    "semver": "^7.7.4",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@types/semver": "^7.5.8",
    "@vitest/coverage-v8": "4.1.4",
    "tsup": "8.5.1",
    "typescript": "6.0.3",
    "vitest": "4.1.4"
  },
  "engines": {
    "node": ">=20.10"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/ganderbite/relay.git",
    "directory": "packages/cli"
  },
  "homepage": "https://ganderbite.github.io/relay",
  "bugs": {
    "url": "https://github.com/ganderbite/relay/issues"
  }
}
