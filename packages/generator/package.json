{
  "name": "@relay/generator",
  "version": "0.1.0",
  "private": false,
  "type": "module",
  "main": "./dist/install.js",
  "types": "./dist/install.d.ts",
  "exports": {
    ".": { "types": "./dist/install.d.ts", "import": "./dist/install.js" },
    "./scaffold": { "types": "./dist/scaffold.d.ts", "import": "./dist/scaffold.js" }
  },
  "bin": {
    "relay-generator": "./bin/install.js",
    "relay-generator-install": "./bin/install.js"
  },
  "files": [
    "skill",
    "templates",
    "dist",
    "bin"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "neverthrow": "^8.2.0"
  },
  "devDependencies": {
    "@types/node": "22.15.3",
    "tsup": "8.5.1",
    "typescript": "6.0.3"
  },
  "engines": {
    "node": ">=25.8"
  }
}
