{
  "name": "@ganderbite/relay-generator",
  "version": "0.2.0",
  "description": "Scaffold new Relay flow packages from templates.",
  "private": false,
  "type": "module",
  "main": "./dist/install.js",
  "types": "./dist/install.d.ts",
  "exports": {
    ".": {
      "types": "./dist/install.d.ts",
      "import": "./dist/install.js"
    },
    "./scaffold": {
      "types": "./dist/scaffold.d.ts",
      "import": "./dist/scaffold.js"
    }
  },
  "bin": {
    "relay-generator": "./bin/install.js",
    "relay-generator-install": "./bin/install.js"
  },
  "files": [
    "skill",
    "templates",
    "dist",
    "bin"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit && tsc --project tsconfig.test.json",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "neverthrow": "^8.2.0"
  },
  "devDependencies": {
    "tsup": "8.5.1",
    "typescript": "6.0.3",
    "vitest": "4.1.4"
  },
  "engines": {
    "node": ">=25.8.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/GanderBite/relay.git",
    "directory": "packages/generator"
  },
  "homepage": "https://ganderbite.github.io/relay",
  "bugs": {
    "url": "https://github.com/GanderBite/relay/issues"
  }
}
