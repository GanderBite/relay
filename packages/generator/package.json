{
  "name": "@relay/generator",
  "version": "0.1.0",
  "private": false,
  "type": "module",
  "main": "./dist/install.js",
  "types": "./dist/install.d.ts",
  "exports": {
    ".": {
      "types": "./dist/install.d.ts",
      "import": "./dist/install.js"
    },
    "./scaffold": {
      "types": "./dist/scaffold.d.ts",
      "import": "./dist/scaffold.js"
    }
  },
  "bin": {
    "relay-generator": "./bin/install.js",
    "relay-generator-install": "./bin/install.js"
  },
  "files": [
    "skill",
    "templates",
    "dist",
    "bin"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit && tsc --project tsconfig.test.json",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "neverthrow": "^8.2.0"
  },
  "devDependencies": {
    "tsup": "8.5.1",
    "typescript": "6.0.3",
    "vitest": "4.1.4"
  },
  "engines": {
    "node": ">=20.10"
  }
}
