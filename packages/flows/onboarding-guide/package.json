{
  "name": "@ganderbite/flow-onboarding-guide",
  "version": "0.1.0",
  "description": "Scans a project directory and produces an audience-specific HTML onboarding guide.",
  "type": "module",
  "main": "./dist/flow.js",
  "exports": {
    ".": {
      "import": "./dist/flow.js"
    }
  },
  "files": [
    "dist",
    "prompts",
    "schemas",
    "templates",
    "examples",
    "README.md"
  ],
  "scripts": {
    "build": "tsc && cp -r prompts dist/",
    "typecheck": "tsc --noEmit",
    "test": "echo 'no unit tests — run relay test . with relay installed'"
  },
  "peerDependencies": {
    "@ganderbite/relay-core": "^1.0.0"
  },
  "devDependencies": {
    "@ganderbite/relay-core": "workspace:*",
    "typescript": "6.0.3"
  },
  "relay": {
    "flowName": "onboarding-guide",
    "displayName": "Onboarding Guide",
    "tags": [
      "discovery",
      "documentation",
      "onboarding"
    ],
    "estimatedCostUsd": {
      "min": 0.3,
      "max": 1.2
    },
    "estimatedDurationMin": {
      "min": 10,
      "max": 30
    },
    "audience": [
      "pm",
      "dev"
    ]
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/ganderbite/relay.git",
    "directory": "packages/flows/onboarding-guide"
  },
  "homepage": "https://ganderbite.github.io/relay",
  "bugs": {
    "url": "https://github.com/ganderbite/relay/issues"
  }
}
