{
  "name": "@ganderbite/flow-spec-generator",
  "version": "0.1.0",
  "description": "Generates a structured feature specification from a plain-language description.",
  "type": "module",
  "main": "./dist/flow.js",
  "exports": {
    ".": {
      "import": "./dist/flow.js"
    }
  },
  "files": [
    "dist",
    "prompts",
    "schemas",
    "templates",
    "examples",
    "README.md"
  ],
  "scripts": {
    "build": "tsc && cp -r prompts dist/",
    "typecheck": "tsc --noEmit",
    "test": "echo 'no unit tests — run relay test . with relay installed'"
  },
  "peerDependencies": {
    "@ganderbite/relay-core": "^0.2.0"
  },
  "devDependencies": {
    "@ganderbite/relay-core": "workspace:*",
    "typescript": "6.0.3"
  },
  "relay": {
    "flowName": "spec-generator",
    "displayName": "spec-generator",
    "tags": [
      "linear",
      "pipeline",
      "spec",
      "documentation"
    ],
    "estimatedCostUsd": {
      "min": 0.05,
      "max": 0.3
    },
    "estimatedDurationMin": {
      "min": 2,
      "max": 10
    },
    "audience": [
      "dev",
      "pm"
    ]
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/GanderBite/relay.git",
    "directory": "packages/flows/spec-generator"
  },
  "homepage": "https://ganderbite.github.io/relay",
  "bugs": {
    "url": "https://github.com/GanderBite/relay/issues"
  }
}
