{
  "name": "@ganderbite/relay-core",
  "version": "0.2.1",
  "description": "Run deterministic multi-step Claude Code workflows with checkpoint and resume.",
  "private": false,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "module": "./dist/index.js",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./testing": {
      "types": "./dist/testing/index.d.ts",
      "import": "./dist/testing/index.js"
    },
    "./live-state": {
      "types": "./dist/orchestrator/live-state.d.ts",
      "import": "./dist/orchestrator/live-state.js"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest"
  },
  "dependencies": {
    "handlebars": "4.7.9",
    "neverthrow": "8.2.0",
    "p-retry": "7.1.1",
    "pino": "10.3.1",
    "pino-pretty": "13.1.3",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "4.1.4",
    "tsup": "8.5.1",
    "typescript": "6.0.3",
    "vitest": "4.1.4"
  },
  "engines": {
    "node": ">=25.8.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/GanderBite/relay.git",
    "directory": "packages/core"
  },
  "homepage": "https://ganderbite.github.io/relay",
  "bugs": {
    "url": "https://github.com/GanderBite/relay/issues"
  }
}
